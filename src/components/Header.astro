---
import ThreatBadge from "./ThreatBadge.astro";

export interface Props {
  mode: "professional" | "terminal";
}

const { mode } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<header class="site-header">
  <div class="container">
    <nav>
      <a href={`${base}/`} class="nav-brand">
        <img src={`${base}/images/netwrix-logo-light.svg`} alt="Netwrix" style="height: 24px;" />
      </a>
      <ul class="nav-links">
        <li><a href={`${base}/`}>Home</a></li>
        <li><a href={`${base}/progress/`}>Progress</a></li>
        <li><a href={`${base}/glossary/`}>Glossary</a></li>
        <li><ThreatBadge /><span class="pages-read" id="pages-read-count" style="font-size: 0.75rem; color: var(--color-muted); margin-left: 0.5rem;"></span></li>
      </ul>
    </nav>
  </div>
</header>

<script>
  function updatePagesRead() {
    const el = document.getElementById("pages-read-count");
    if (!el) return;
    try {
      const raw = localStorage.getItem("attackCatalog");
      if (!raw) { el.textContent = "0%"; return; }
      const data = JSON.parse(raw);
      const count = Object.keys(data.pages || {}).length;
      const pct = Math.min(Math.round((count / 132) * 100), 100);
      el.textContent = `${pct}%`;
    } catch { el.textContent = ""; }
  }
  document.addEventListener("DOMContentLoaded", updatePagesRead);
  document.addEventListener("astro:page-load", updatePagesRead);
  document.addEventListener("attackCatalog:pageRead", updatePagesRead);
</script>
