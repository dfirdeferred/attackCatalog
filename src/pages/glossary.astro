---
import ProfessionalLayout from "@layouts/ProfessionalLayout.astro";
import { getCollection } from "astro:content";

const allAttacks = await getCollection("attacks");

// Build glossary terms from attacks
interface GlossaryTerm {
  term: string;
  definition: string;
  attackSlug: string;
}

const terms: GlossaryTerm[] = allAttacks
  .map((attack) => ({
    term: attack.data.title.replace(/ Attack$/, "").replace(/ Vulnerability$/, ""),
    definition: `${attack.data.severity} severity ${attack.data.category.toLowerCase()} technique targeting ${attack.data.targets.join(", ")}.`,
    attackSlug: attack.data.slug,
  }))
  .sort((a, b) => a.term.localeCompare(b.term));

// Group by first letter
const grouped = new Map<string, GlossaryTerm[]>();
for (const term of terms) {
  const letter = term.term.charAt(0).toUpperCase();
  if (!grouped.has(letter)) {
    grouped.set(letter, []);
  }
  grouped.get(letter)!.push(term);
}

const letters = [...grouped.keys()].sort();
---

<ProfessionalLayout title="Glossary">
  <h1 class="mb-2">Glossary</h1>
  <p class="text-muted mb-4">Alphabetical index of security terms covered in this catalog.</p>

  <!-- Letter navigation -->
  <nav class="glossary-letters mb-4" style="display: flex; flex-wrap: wrap; gap: 0.5rem;">
    {letters.map((letter) => (
      <a href={`#letter-${letter}`} style="font-weight: 600; font-size: 0.875rem;">
        {letter}
      </a>
    ))}
  </nav>

  <!-- Terms -->
  {letters.map((letter) => (
    <section id={`letter-${letter}`} class="mb-4">
      <h2 style="font-size: 1.5rem; font-weight: 800; color: var(--color-link); border-bottom: 2px solid var(--color-border); padding-bottom: 0.375rem; margin-bottom: 0.75rem;">
        {letter}
      </h2>
      <dl style="display: flex; flex-direction: column; gap: 0.75rem;">
        {grouped.get(letter)!.map((entry) => (
          <div>
            <dt style="font-weight: 700; font-size: 1rem;">
              <a href={`/c-level/${entry.attackSlug}/`}>
                {entry.term}
              </a>
            </dt>
            <dd class="text-muted text-small" style="margin-left: 0; margin-top: 0.125rem;">
              {entry.definition}
            </dd>
          </div>
        ))}
      </dl>
    </section>
  ))}
</ProfessionalLayout>
