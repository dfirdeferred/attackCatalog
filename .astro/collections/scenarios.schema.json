{
  "$ref": "#/definitions/scenarios",
  "definitions": {
    "scenarios": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "chain": {
          "type": "string"
        },
        "chainOrder": {
          "type": "integer",
          "exclusiveMinimum": 0
        },
        "role": {
          "type": "string",
          "enum": [
            "c-level",
            "it-admin",
            "end-user",
            "red-teamer"
          ]
        },
        "attack": {
          "type": "string"
        },
        "choices": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": {
                "type": "string"
              },
              "next": {
                "type": "string"
              }
            },
            "required": [
              "label",
              "next"
            ],
            "additionalProperties": false
          },
          "default": []
        },
        "isDebrief": {
          "type": "boolean",
          "default": false
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "title",
        "chain",
        "chainOrder",
        "role",
        "attack"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}